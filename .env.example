# Application configuration
# APP_NAME=WordOfTheDayApp
# APP_VERSION=1.0.0
# CONTACT_EMAIL=your@email.com

# API credentials
NYT_API_KEY=
MERRIAM_WEBSTER_API_KEY=

# Connector Base URLs (overrides)
# NYT_BASE_URL=https://api.nytimes.com
# POETRY_DB_BASE_URL=https://poetrydb.org
# QUOTABLE_BASE_URL=https://api.quotable.io
# SUBSTACK_BASE_URL=https://substack.com
# WIKIPEDIA_BASE_URL=https://en.wikipedia.org
# DICTIONARY_BASE_URL=https://www.dictionaryapi.com/api/v3/references/collegiate/json/
# FREE_DICTIONARY_BASE_URL=https://api.dictionaryapi.dev/api/v2/entries/en/

# Wikipedia Connector User-Agent details (specific overrides)
# WIKIPEDIA_APP_NAME=WordOfTheDayApp
# WIKIPEDIA_CONTACT_EMAIL=fritz@example.com
# WIKIPEDIA_VERSION=1.0.0

# PoetryDB Connector User-Agent details (specific overrides)
# POETRY_DB_APP_NAME=WordOfTheDay
# POETRY_DB_VERSION=1.0
# POETRY_DB_CONTACT_EMAIL=fritz@example.com

# Application Parameters
# MIN_SCORE=2.3
# MAX_SCORE=4.0
# LIMIT=3
# USE_EMBEDDINGS=True
# CLUSTER_KNN_ENABLED=True
# SELECTION_STRATEGY=softmax
# SELECTION_TEMPERATURE=1.0
# USE_LEMMATIZATION=True
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_K=5
# SEED_CSV_PATH=word_of_the_day_embeddings.csv
# CACHE_NPZ_PATH=word_of_the_day_embeddings.npz
# POS_FILTER_NOUNS=True
# POS_FILTER_ADJECTIVES=True
# POS_FILTER_VERBS=True
# MIN_WORD_LENGTH=
# MAX_WORD_LENGTH=

# Logging configurations
# LOG_FILE=logs/app.log
# LOG_LEVEL=INFO
# LOG_LEVEL_CONSOLE=INFO
# LOG_LEVEL_FILE=DEBUG
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# Web / API Security
# Restrict to your production domain(s). Example: ["https://yourdomain.com"]
#CORS_ORIGINS=["https://yourdomain.com"]
# Set to True in production to hide /docs, /redoc, and /openapi.json
#DISABLE_API_DOCS=True

# Podcast RSS feed URL for bootstrapping
# PODCAST_FEED_URL=https://rss.art19.com/merriam-websters-word-of-the-day

# SMTP / Email Pipeline configuration
# SMTP_BACKEND=console
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@wordoftheday.com
# SMTP_FROM_NAME=word.
# SMTP_USE_TLS=True
# SMTP_USE_SSL=False
# SMTP_MAX_EMAILS_PER_DAY=200
# SMTP_ADMIN_NOTIFICATION_EMAIL=admin@example.com
# APP_BASE_URL=http://localhost:8000
